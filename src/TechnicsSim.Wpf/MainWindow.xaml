<Window x:Class="TechnicsSim.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hx="http://helix-toolkit.org/wpf/SharpDX"
        xmlns:vm="clr-namespace:TechnicsSim.Wpf.ViewModels"
        Title="TechnicsSimulator" Height="800" Width="1280"
        Background="#1E1E1E">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <vm:EnumOptionConverter x:Key="EnumOption" />
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DDDDDD" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#DDDDDD" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style x:Key="Mono" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DDDDDD" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="Dim" TargetType="TextBlock" BasedOn="{StaticResource Mono}">
            <Setter Property="Foreground" Value="#999999" />
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4EC9B0" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,10,0,4" />
        </Style>
        <Style x:Key="RowCard" TargetType="Border">
            <Setter Property="Background" Value="#2A2A2C" />
            <Setter Property="BorderBrush" Value="#3E3E42" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="ReasonBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="BorderBrush" Value="#3E3E42" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
        <Style x:Key="ReviewToggle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#DDDDDD" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#2D2D30" Padding="8,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Model:" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox x:Name="ModelSelector" Width="340" VerticalAlignment="Center"
                          SelectionChanged="OnModelSelected" />
                <Button Content="Zoom to fit" Click="OnZoomToFit" Margin="8,0,6,0" />
                <Button Content="Zoom to selection" Click="OnZoomToSelection" />
                <CheckBox Content="Edges" IsChecked="{Binding ShowEdges}" />
                <CheckBox Content="Diagnostics (bounds + features + mates)" IsChecked="{Binding ShowDiagnostics}" />
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#007ACC" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Status}" Foreground="White" />
                <TextBlock Grid.Column="1" Text="{Binding LibraryDescription}" Foreground="#DDEEFF" />
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" MinWidth="200" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TabControl Grid.Column="0" Background="#252526" BorderThickness="0">
                <TabItem Header="Model tree">
                    <DockPanel Background="#252526">
                        <Border DockPanel.Dock="Bottom" Background="#1E1E1E" Padding="8,6" MinHeight="70">
                            <TextBlock Text="{Binding SelectionDetail}" TextWrapping="Wrap"
                                       FontFamily="Consolas" FontSize="11" />
                        </Border>
                        <TreeView x:Name="Tree" ItemsSource="{Binding Tree}"
                                  Background="#252526" Foreground="#DDDDDD" BorderThickness="0"
                                  SelectedItemChanged="OnTreeSelectionChanged">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Label}" />
                                        <TextBlock Text="{Binding CountLabel}" Foreground="#888888" Margin="6,0,0,0" />
                                        <TextBlock Text="{Binding Detail}" Foreground="#6A9955" Margin="6,0,0,0" />
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </DockPanel>
                </TabItem>

                <TabItem Header="Mechanics" DataContext="{Binding Mechanics}">
                    <DockPanel Background="#252526">
                        <Border DockPanel.Dock="Top" Background="#1E1E1E" Padding="8,6">
                            <StackPanel>
                                <TextBlock Text="{Binding Summary}" Style="{StaticResource Mono}" />
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button Content="Export sidecar" Command="{Binding ExportCommand}" />
                                    <Button Content="Revert" Command="{Binding RevertCommand}" />
                                </StackPanel>
                                <TextBlock Text="{Binding ExportStatus}" Style="{StaticResource Dim}" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>

                        <Border DockPanel.Dock="Top" Background="#4A1F1F" Padding="8,6"
                                Visibility="{Binding HasStaleWarnings, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel>
                                <TextBlock Text="Stale sidecar entries: the model changed under these overrides."
                                           Foreground="#FFB0B0" FontWeight="Bold" TextWrapping="Wrap" />
                                <ItemsControl ItemsSource="{Binding StaleWarnings}" Margin="0,4,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Style="{StaticResource Mono}" Foreground="#FFD0D0" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,0">
                            <StackPanel>
                                <TextBlock Text="Gear meshes" Style="{StaticResource SectionHeader}" />
                                <ItemsControl ItemsSource="{Binding Meshes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource RowCard}">
                                                <StackPanel>
                                                    <DockPanel>
                                                        <TextBlock DockPanel.Dock="Right" Text="{Binding ConfidenceLabel}"
                                                                   Style="{StaticResource Dim}" />
                                                        <TextBlock Text="{Binding Headline}" Style="{StaticResource Mono}"
                                                                   Foreground="#DCDCAA" FontWeight="Bold" />
                                                    </DockPanel>
                                                    <TextBlock Text="{Binding Parts}" Style="{StaticResource Dim}" />
                                                    <TextBlock Text="{Binding Metrics}" Style="{StaticResource Dim}" />
                                                    <TextBlock Text="{Binding Provenance}" Style="{StaticResource Dim}"
                                                               Foreground="#6A9955" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <RadioButton Content="auto" Style="{StaticResource ReviewToggle}"
                                                                     GroupName="{Binding Parts}"
                                                                     IsChecked="{Binding Decision, Mode=TwoWay,
                                                                         Converter={StaticResource EnumOption}, ConverterParameter=None}" />
                                                        <RadioButton Content="accept" Style="{StaticResource ReviewToggle}"
                                                                     GroupName="{Binding Parts}"
                                                                     IsChecked="{Binding Decision, Mode=TwoWay,
                                                                         Converter={StaticResource EnumOption}, ConverterParameter=Accept}" />
                                                        <RadioButton Content="reject" Style="{StaticResource ReviewToggle}"
                                                                     GroupName="{Binding Parts}"
                                                                     IsChecked="{Binding Decision, Mode=TwoWay,
                                                                         Converter={StaticResource EnumOption}, ConverterParameter=Reject}" />
                                                        <TextBlock Text="{Binding StatusLabel}" Style="{StaticResource Dim}" />
                                                    </StackPanel>
                                                    <TextBox Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource ReasonBox}"
                                                             Visibility="{Binding IsReviewed, Converter={StaticResource BoolToVisibility}}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Clutches (locked lets torque propagate)" Style="{StaticResource SectionHeader}" />
                                <ItemsControl ItemsSource="{Binding Clutches}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource RowCard}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Headline}" Style="{StaticResource Mono}"
                                                               Foreground="#DCDCAA" FontWeight="Bold" />
                                                    <TextBlock Text="{Binding BoundaryReason}" Style="{StaticResource Dim}" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <RadioButton Content="unreviewed" Style="{StaticResource ReviewToggle}"
                                                                     GroupName="{Binding InstanceId}"
                                                                     IsChecked="{Binding State, Mode=TwoWay,
                                                                         Converter={StaticResource EnumOption}, ConverterParameter=None}" />
                                                        <RadioButton Content="locked" Style="{StaticResource ReviewToggle}"
                                                                     GroupName="{Binding InstanceId}"
                                                                     IsChecked="{Binding State, Mode=TwoWay,
                                                                         Converter={StaticResource EnumOption}, ConverterParameter=Locked}" />
                                                        <RadioButton Content="free" Style="{StaticResource ReviewToggle}"
                                                                     GroupName="{Binding InstanceId}"
                                                                     IsChecked="{Binding State, Mode=TwoWay,
                                                                         Converter={StaticResource EnumOption}, ConverterParameter=Free}" />
                                                        <TextBlock Text="{Binding StatusLabel}" Style="{StaticResource Dim}" />
                                                    </StackPanel>
                                                    <TextBox Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource ReasonBox}"
                                                             Visibility="{Binding IsReviewed, Converter={StaticResource BoolToVisibility}}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Drivers (motors)" Style="{StaticResource SectionHeader}" />
                                <ItemsControl ItemsSource="{Binding Drivers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource RowCard}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Headline}" Style="{StaticResource Mono}"
                                                               Foreground="#DCDCAA" FontWeight="Bold" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <CheckBox Content="driver" IsChecked="{Binding IsDriver, Mode=TwoWay}"
                                                                  Margin="0,0,8,0" />
                                                        <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                                                 Width="180" Background="#1E1E1E" Foreground="#CCCCCC"
                                                                 BorderBrush="#3E3E42" FontSize="11" />
                                                    </StackPanel>
                                                    <TextBox Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource ReasonBox}"
                                                             Visibility="{Binding IsReviewed, Converter={StaticResource BoolToVisibility}}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Unsupported boundaries (propagation stops here)"
                                           Style="{StaticResource SectionHeader}" />
                                <ItemsControl ItemsSource="{Binding Boundaries}" Margin="0,0,0,12">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource RowCard}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Headline}" Style="{StaticResource Mono}"
                                                               Foreground="#CE9178" />
                                                    <TextBlock Text="{Binding BoundaryReason}" Style="{StaticResource Dim}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#3E3E42" />

            <Grid Grid.Column="2">
                <hx:Viewport3DX x:Name="Viewport"
                                BackgroundColor="#FF202020"
                                ShowCoordinateSystem="True"
                                ShowViewCube="True"
                                UseDefaultGestures="True"
                                CameraRotationMode="Turntable"
                                ZoomExtentsWhenLoaded="False"
                                PreviewMouseLeftButtonDown="OnViewportPress"
                                PreviewMouseLeftButtonUp="OnViewportRelease">
                    <hx:Viewport3DX.Camera>
                        <hx:PerspectiveCamera Position="600,400,600" LookDirection="-600,-400,-600"
                                              UpDirection="0,1,0"
                                              NearPlaneDistance="1" FarPlaneDistance="20000" />
                    </hx:Viewport3DX.Camera>
                    <hx:AmbientLight3D Color="#FF555555" />
                    <hx:DirectionalLight3D Color="#FFBBBBBB" Direction="-0.6,-1,-0.4" />
                    <hx:DirectionalLight3D Color="#FF555555" Direction="0.7,0.4,0.6" />
                </hx:Viewport3DX>

                <TextBlock Text="{Binding Statistics}" Foreground="#AAAAAA" FontFamily="Consolas"
                           FontSize="11" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                           Margin="10" IsHitTestVisible="False" />

                <Border Background="#AA000000" Padding="7,4" HorizontalAlignment="Right"
                        VerticalAlignment="Top" Margin="10" IsHitTestVisible="False"
                        Visibility="{Binding ShowDiagnostics, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock FontFamily="Consolas" FontSize="11">
                        <Run Text="axes " Foreground="DeepSkyBlue" />
                        <Run Text="matched " Foreground="Cyan" />
                        <Run Text="unmatched " Foreground="Orange" />
                        <Run Text="ambiguous " Foreground="Magenta" />
                        <Run Text="mate" Foreground="LimeGreen" />
                    </TextBlock>
                </Border>

                <Border Background="#AA000000" IsHitTestVisible="False"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="Loading..." Foreground="White" FontSize="18"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
